{
  "schemaVersion": 1,
  "id": "queue-notice",
  "version": "${version}",
  "name": "xYuan's Mod",
  "description": "Meteor addon that monitors server queue position and pushes progress reminders to a Feishu custom bot webhook.",
  "authors": [
    "xYuan"
  ],
  "contact": {
    "sources": "https://github.com/MeteorDevelopment/meteor-addon-template"
  },
  "icon": "assets/queue-notice/icon.png",
  "environment": "client",
  "entrypoints": {
    "meteor": [
      "cn.anyho.xyuan.QueueNoticeAddon"
    ]
  },
  "custom": {
    "meteor-client:color": "25,225,225",
    "modmenu": {
      "parent": {
        "id": "meteor-client"
      }
    }
  },
  "depends": {
    "java": ">=21",
    "minecraft": ["${mc_version}"],
    "meteor-client": "*"
  }
}
